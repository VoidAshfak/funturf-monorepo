{
  "name": "funturf",
  "version": "1.0.0",
  "description": "A turf booking and game organizing platform",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon --exec \"node -r dotenv/config\" src/index.js",
    "dev:docs": "cross-env DOCS_ENABLED=true nodemon --exec \"node -r dotenv/config\" src/index.js",
    "prisma:generate:pg": "prisma generate --schema=prisma/postgresql/schema.prisma",
    "prisma:generate:mongo": "prisma generate --schema=prisma/mongodb/schema.prisma",
    "prisma:generate": "npm run prisma:generate:pg && npm run prisma:generate:mongo",
    "prisma:migrate": "prisma migrate dev --schema=prisma/postgresql/schema.prisma",
    "prisma:push:mongo": "prisma db push --schema=prisma/mongodb/schema.prisma",
    "prisma:push:pgsql": "prisma db push --schema=prisma/postgresql/schema.prisma"
  },
  "keywords": [
    "turf",
    "football",
    "play",
    "game",
    "fun",
    "booking"
  ],
  "author": "Asfaqul Asif",
  "license": "ISC",
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "prisma": "^6.7.0"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.6.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.18.3",
    "yaml": "^2.9.0"
  }
}
