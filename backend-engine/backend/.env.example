# =============================================================================
# FunTurf API — environment template
# =============================================================================
# Copy to `.env` and fill in real values:   cp .env.example .env
# `.env` is gitignored and .dockerignored — it never enters an image layer.
#
# This ONE file drives all three ways of running the API:
#   - host dev      : npm run dev                (reads .env via dotenv)
#   - local cluster : docker compose up          (reads .env via env_file)
#   - production    : Render dashboard           (see ../render.yaml; secrets are
#                                                 `sync: false` and set by hand)
# =============================================================================

# --- Server ------------------------------------------------------------------
PORT=8080

# `production` enables Express optimisations and, by default, HIDES the Swagger
# docs. Use `development` for host dev unless you're deliberately testing
# prod-like behaviour.
NODE_ENV=development

# Slot/booking maths runs against Bangladesh local time (UTC+06:00) while servers
# run on UTC. 360 = +6h in minutes. Only change this if the app is ever operated
# from another timezone.
APP_TZ_OFFSET_MINUTES=360

# --- Databases ---------------------------------------------------------------
# Prisma `pg` datasource — the authoritative domain model.
# Hosted (Aiven) — what the app uses by default:
POSTGRESQL_DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<database>?sslmode=require
#
# LOCAL alternative: to use the postgres container from ../docker-compose.yml,
# comment the line above and uncomment this one. `db` is the compose service
# name, so this URL only resolves from INSIDE the cluster — from your host use
# 127.0.0.1:8000 instead (that's the published port).
# POSTGRESQL_DATABASE_URL=postgresql://funturf:funturf@db:5432/funturf-dev

# Credentials the postgres CONTAINER initialises itself with on first boot. Must
# match the local URL above. Changing them later does nothing unless the volume
# is wiped: `docker compose down -v`.
POSTGRES_USER=funturf
POSTGRES_PASSWORD=funturf
POSTGRES_DB=funturf-dev

# Prisma `mongo` datasource. DEPRECATED — do not write new code against it, but
# src/prisma.js still imports the client, so the process crashes on boot if this
# is missing. Remove once user.controller.js / turfmate.controller.js are migrated.
MONGO_DATABASE_URL=mongodb+srv://<user>:<password>@<host>/<database>

# --- Socket.IO backplane -----------------------------------------------------
# Leave UNSET for host dev: a single process needs no backplane, and src/socket.js
# falls back to the in-memory adapter.
# docker-compose sets this to redis://redis:6379 automatically; Render injects it
# from the managed Key Value instance. You should rarely set it by hand.
# REDIS_URL=redis://localhost:6379

# --- Auth --------------------------------------------------------------------
# Generate strong, DISTINCT secrets — never reuse the production values locally:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=<64-byte-random-hex>
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=<64-byte-random-hex-different-from-above>
REFRESH_TOKEN_EXPIRY=10d

# --- CORS --------------------------------------------------------------------
# Comma-separated browser origins allowed to call the API. No trailing slashes.
# Feeds BOTH the REST CORS layer and the Socket.IO handshake via
# src/utils/corsOrigins.js. Never use "*" — credentials are enabled.
CORS_ORIGINS=http://localhost:3000,https://funturf-frontend.vercel.app

# --- Cloudinary (image uploads) ----------------------------------------------
# Note: `cloud_name` is currently hardcoded to 'funturf' in src/utils/mediaUpload.js,
# so there is no CLOUDINARY_CLOUD_NAME variable.
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_SECRET_KEY=<api-secret>

# --- API docs ----------------------------------------------------------------
# Swagger UI at /api/v1/docs. Hidden when NODE_ENV=production unless this is
# true. Keep it false in production: a full endpoint inventory is free recon.
DOCS_ENABLED=true
